# saegim RAG — LLM 레이어 설정. 이 파일을 .env 로 복사하고 값 채우기.
# .env 는 .gitignore 로 추적 안 됨. 실제 키를 여기(.env.example)에 적지 말 것.

# 활성화 (필수): console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# 선택: 모델 오버라이드 (기본 claude-haiku-4-5-20251001)
# SAEGIM_LLM_MODEL=claude-haiku-4-5-20251001
# SAEGIM_LLM_MODEL_SLOTS=claude-haiku-4-5-20251001     # (a) 슬롯필러 전용
# SAEGIM_LLM_MODEL_NARRATE=claude-haiku-4-5-20251001   # (b) 생성층 전용

# 선택: 호출 안정성
# SAEGIM_LLM_TIMEOUT=30
# SAEGIM_LLM_RETRIES=2
